# Server Configuration
PORT=5500
NODE_ENV=development

# JWT Secret (32+ characters recommended)
JWT_SECRET=your_jwt_secret_key_here_32_chars_min

# Admin User Configuration
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@yoursite.com
ADMIN_PASSWORD=your_secure_password

# Custom Admin User (Optional)
CUSTOM_ADMIN_NAME=Your Name
CUSTOM_ADMIN_EMAIL=your@email.com
CUSTOM_ADMIN_PASSWORD=your_secure_password

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Your Site <your_email@gmail.com>
SMTP_TO=admin@yoursite.com

# Payment Provider (Iyzico)
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
